{% macro render_menu(items, attributes, menu_level) %}
  {% import _self as macros %}
  {% if items %}
    <ul{{ attributes.addClass(menu_level > 0 ? 'submenu' : '') }}>
      {% for item in items %}
         <li class="menu-item-wrapper"{{ item.attributes.addClass(item.in_active_trail ? 'is-active' : '') }}>
          {% if item.url.isRouted and item.url.routeName != '<nolink>' %}
            <a href="{{ item.url }}">{{ item.title }}</a>
          {% else %}
            <span>{{ item.title }}</span>
          {% endif %}
          {# Renderiza hijos recursivamente #}
          {% if item.below %}
            {{ macros.render_menu(item.below, attributes, menu_level + 1) }}
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}

{{ _self.render_menu(items, attributes, 0) }}
